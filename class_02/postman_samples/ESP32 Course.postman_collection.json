									"// Visualization Script",
									"// Visualization Script",
									"const template = `",
									"<div style=\"font-family: Arial, sans-serif; max-width: 500px; margin: 0 auto;\">",
									"  <h3>Delete Student Result</h3>",
									"  <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 16px;\">",
									"    <tr>",
									"      <th style=\"text-align: left; padding: 4px; background: #f2f2f2;\">Status</th>",
									"      <td style=\"padding: 4px;\">{{status}}</td>",
									"    </tr>",
									"    <tr>",
									"      <th style=\"text-align: left; padding: 4px; background: #f2f2f2;\">Message</th>",
									"      <td style=\"padding: 4px;\">{{message}}</td>",
									"    </tr>",
									"  </table>",
									"  <h4>Deleted Student Details</h4>",
									"  <table style=\"width: 100%; border-collapse: collapse;\">",
									"    <tr>",
									"      <th style=\"text-align: left; padding: 4px; background: #f9f9f9;\">First Name</th>",
									"      <td style=\"padding: 4px;\">{{deleted_student.fname}}</td>",
									"    </tr>",
									"    <tr>",
									"      <th style=\"text-align: left; padding: 4px; background: #f9f9f9;\">Last Name</th>",
									"      <td style=\"padding: 4px;\">{{deleted_student.lname}}</td>",
									"    </tr>",
									"    <tr>",
									"      <th style=\"text-align: left; padding: 4px; background: #f9f9f9;\">Phone</th>",
									"      <td style=\"padding: 4px;\">{{deleted_student.phone}}</td>",
									"    </tr>",
									"    <tr>",
									"      <th style=\"text-align: left; padding: 4px; background: #f9f9f9;\">Email</th>",
									"      <td style=\"padding: 4px;\">{{deleted_student.email}}</td>",
									"    </tr>",
									"  </table>",
									"</div>`;",
									"",
									"function createPayload() {",
									"  let data = {};",
									"  try {",
									"    data = pm.response.json();",
									"  } catch (e) {}",
									"  return data;",
									"}",
									"",
									"pm.visualizer.set(template, createPayload());"
								],
